---
import Base from '../layouts/Base.astro';
import { skin } from '../content/skin';
import { readdirSync } from 'node:fs';
import { fileURLToPath } from 'node:url';

const { hud, journey, facts, suites, sphere, water, amenities, rate, agent, gallery, cta, meta } = skin;

// Frame counts come from the files actually on disk, not a hand-typed number —
// a count/disk mismatch makes the scrubber request 404s and the hero appears frozen.
const countFrames = (dir: string) => {
  try {
    return readdirSync(fileURLToPath(new URL(`../../public/frames/${dir}/`, import.meta.url)))
      .filter((f) => /^frame_\d+\.webp$/.test(f)).length;
  } catch {
    return 0;
  }
};
const frames = {
  ...journey.frames,
  count: countFrames('hero') || journey.frames.count,
  mobileCount: countFrames('hero-mobile') || journey.frames.mobileCount,
};
---

<Base>
  <!-- JOURNEY — 6-clip chained tour (sky → restaurant → lounge → suite → spa → lake), scrubbed as ONE unbroken glide. -->
  <section
    class="journey"
    id="tour"
    data-journey
    data-frames={JSON.stringify(frames)}
    data-hud={JSON.stringify(hud.spaces)}
    data-altitude={hud.altitude}
    data-hud-prefix={hud.prefix}
    data-hud-unit={hud.unit}
    data-hud-locale={hud.locale}
  >
    <div class="journey__sticky">
      <canvas data-journey-canvas></canvas>
      <div class="journey__scrim" aria-hidden="true"></div>

      {journey.chapters.map((ch, i) => (
        <div class:list={['journey__chapter', `journey__chapter--${i % 2 ? 'right' : 'left'}`]} data-chapter id={ch.id}>
          <p class="kicker">{ch.kicker}</p>
          {i === 0
            ? <h1 class="journey__display">{ch.title}</h1>
            : <h2 class="journey__title">{ch.title}</h2>}
          <p class="journey__body">{ch.body}</p>
          {'rooms' in ch && ch.rooms && (
            <div class="rooms">
              {ch.rooms.map((r) => (
                <article class="room">
                  <div class="media media--room">
                    <img data-media src={r.img} alt={r.name} loading="lazy" />
                    <span class="media__label" aria-hidden="true">{r.name}</span>
                  </div>
                  <h3 class="room__name">{r.name}</h3>
                  <p class="room__line">{r.line}</p>
                </article>
              ))}
            </div>
          )}
        </div>
      ))}

      <div class="hud" data-hud-root aria-hidden="true">
        <span class="hud__alt" data-hud-alt>{hud.prefix}0{hud.unit}</span>
        <span class="hud__track"><i data-hud-fill></i></span>
        <span class="hud__space" data-hud-space>{hud.spaces[0].label}</span>
      </div>

      <div class="journey__hint" data-scroll-hint aria-hidden="true">
        <span></span>{journey.scrollHint}
      </div>
    </div>
  </section>

  <!-- THE NUMBERS — one cinematic statement: oversized Fraunces numerals as index rows -->
  <section class="numbers" aria-label="The resort in numbers">
    <p class="kicker numbers__kicker" data-reveal>{facts.kicker}</p>
    {facts.items.map((f, i) => (
      <div class="numbers__row" data-reveal>
        <span class="numbers__index" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
        <span
          class="numbers__value"
          data-count={f.value}
          data-format={f.format}
          data-suffix={f.suffix}
          data-decimals={f.decimals}
        >0</span>
        <span class="numbers__meta">
          <span class="numbers__label">{f.label}</span>
          <span class="numbers__line">{f.line}</span>
        </span>
      </div>
    ))}
  </section>

  <!-- THE SUITES — asymmetric editorial spread -->
  <section class="suites" id="suites">
    <div class="suites__copy" data-reveal>
      <p class="kicker">{suites.kicker}</p>
      <h2 class="section-title">{suites.title}</h2>
      <p class="section-body">{suites.body}</p>
      <a class="suites__link" href={suites.linkHref}>{suites.linkLabel} →</a>
    </div>
    <div class="suites__spread">
      <figure class="suites__fig suites__fig--large" data-reveal>
        <div class="media suites__media" style={`aspect-ratio: ${suites.images[0].ratio}`}>
          <img data-media data-parallax="0.12" src={suites.images[0].src} alt={suites.images[0].alt} loading="lazy" />
        </div>
        <figcaption class="suites__cap">{suites.images[0].caption}</figcaption>
      </figure>
      <figure class="suites__fig suites__fig--small" data-reveal>
        <div class="media suites__media" style={`aspect-ratio: ${suites.images[1].ratio}`}>
          <img data-media data-parallax="0.18" src={suites.images[1].src} alt={suites.images[1].alt} loading="lazy" />
        </div>
        <figcaption class="suites__cap">{suites.images[1].caption}</figcaption>
      </figure>
    </div>
  </section>

  <!-- GALLERY — HOLD AND MOVE -->
  <section class="gallery" id="gallery" data-strip>
    <p class="kicker gallery__kicker">{gallery.kicker}</p>
    <div class="gallery__track" data-strip-track>
      {gallery.images.map((g, i) => (
        <figure class="gallery__item">
          <div class="media gallery__media">
            <img data-media src={g.src} alt={g.alt} loading="lazy" draggable="false" />
            <span class="media__label" aria-hidden="true">{g.alt}</span>
          </div>
          <figcaption class="gallery__cap">
            <span class="gallery__cap-index">{String(i + 1).padStart(2, '0')}</span>
            {g.alt}
          </figcaption>
        </figure>
      ))}
    </div>
    <div class="gallery__hint" data-strip-hint aria-hidden="true">{gallery.hint}</div>
  </section>

  <!-- THE SPHERE — full-bleed statement -->
  <section class="sphere" id="sphere" data-sphere>
    <div class="sphere__pin">
      <div class="sphere__media">
        <img data-media data-parallax="0.08" data-parallax-scale src={sphere.img} alt={sphere.imgAlt} loading="lazy" />
      </div>
      <div class="sphere__scrim" aria-hidden="true"></div>
      <div class="sphere__copy" data-reveal>
        <p class="kicker">{sphere.kicker}</p>
        <p class="sphere__line">{sphere.line}</p>
      </div>
    </div>
  </section>

  <!-- THE WATER — scroll-driven horizontal panel (sticky pin, real movement, no editing grammar) -->
  <section class="water" id="water" data-hscroll>
    <div class="water__pin">
      <div class="water__head" data-reveal>
        <p class="kicker">{water.kicker}</p>
        <h2 class="section-title">{water.title}</h2>
        <p class="section-body">{water.body}</p>
      </div>
      <div class="water__track" data-hscroll-track>
        {water.images.map((img) => (
          <figure class="water__panel">
            <div class="media water__media">
              <img data-media src={img.src} alt={img.alt} loading="lazy" />
              <span class="media__label" aria-hidden="true">{img.caption}</span>
            </div>
            <figcaption class="water__cap">{img.caption}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- AMENITIES — typographic index: numbered display rows, hover media preview -->
  <section class="amenities" id="amenities">
    <p class="kicker" data-reveal>{amenities.kicker}</p>
    <h2 class="section-title" data-reveal>{amenities.title}</h2>
    <ul class="am-index" data-am-index>
      {amenities.items.map((item, i) => (
        <li class="am-index__item" data-reveal>
          <span class="am-index__no" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
          <span class="am-index__label">{item.label}</span>
          {'img' in item && item.img && (
            <span class="am-index__preview" aria-hidden="true">
              <img src={item.img} alt="" loading="lazy" />
            </span>
          )}
        </li>
      ))}
    </ul>
  </section>

  <!-- THE RATE + REQUEST — one closing statement (rate folded into the enquiry) -->
  <section class="inquiry" id="enquire">
    <p class="kicker" data-reveal>{rate.kicker}</p>
    <p class="inquiry__rate" data-reveal>{rate.amount}</p>
    <p class="inquiry__rate-line" data-reveal>{rate.line}</p>
    <h2 class="inquiry__title" data-reveal>{cta.title}</h2>
    <p class="section-body inquiry__sub" data-reveal>{cta.sub}</p>
    <div class="inquiry__grid" data-reveal>
      <form class="inquiry__form" data-inquiry novalidate>
        <p class="inquiry__regarding" data-inquiry-regarding hidden>
          Regarding: <span data-inquiry-suite></span>
        </p>
        <input type="hidden" name="suite" />
        <div class="inquiry__row">
          <label class="field">
            <span>{cta.fields.date}</span>
            <input type="date" name="date" required />
          </label>
          <label class="field field--wide">
            <span>{cta.fields.name}</span>
            <input type="text" name="name" required autocomplete="name" />
          </label>
        </div>
        <label class="field field--full">
          <span>{cta.fields.email}</span>
          <input type="email" name="email" required autocomplete="email" />
        </label>
        <button class="btn" type="submit">{cta.submit}</button>
        <p class="inquiry__toast" data-toast role="status" aria-live="polite" hidden>{cta.toast}</p>
      </form>
      <aside class:list={['agent', { 'agent--typo': !agent.showPortrait }]}>
        {agent.showPortrait && (
          <div class="media media--agent">
            <img data-media src={agent.img} alt={agent.imgAlt} loading="lazy" />
          </div>
        )}
        <p class="agent__kicker kicker">{agent.kicker}</p>
        <div class="agent__rule" aria-hidden="true"></div>
        <h3 class="agent__name">{agent.name}</h3>
        <p class="agent__role">{agent.role}</p>
        {agent.lines.map((line) => <p class="agent__line">{line}</p>)}
        <p class="agent__contact">
          <a href={meta.telHref}>{meta.tel}</a><br />
          <a href={`mailto:${meta.email}`}>{meta.email}</a>
        </p>
      </aside>
    </div>
  </section>

  <script src="../scripts/journey.js"></script>
  <script>
    // WATER — scroll-driven horizontal panel (property-level composition; engine stays fork-free).
    // The pin is CSS sticky; this only maps section progress -> track translateX.
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const section = document.querySelector('[data-hscroll]');
    const track = document.querySelector('[data-hscroll-track]');
    if (section && track && !reduced) {
      let ticking = false;
      const update = () => {
        ticking = false;
        const r = section.getBoundingClientRect();
        const total = section.offsetHeight - innerHeight;
        const p = total <= 0 ? 1 : Math.max(0, Math.min(1, -r.top / total));
        const max = track.scrollWidth - track.parentElement.clientWidth;
        track.style.transform = `translate3d(${-p * Math.max(0, max)}px, 0, 0)`;
      };
      addEventListener('scroll', () => { if (!ticking) { ticking = true; requestAnimationFrame(update); } }, { passive: true });
      addEventListener('resize', update);
      update();
    }

    // Preloader %: real coarse-spine (every 4th frame) load progress, not a timer.
    const pct = document.querySelector('[data-preload-pct]');
    if (pct && !reduced) {
      const timer = setInterval(() => {
        const s = window.__scrubber;
        const pre = document.querySelector('[data-preloader]');
        if (!pre || pre.classList.contains('is-done')) { clearInterval(timer); return; }
        if (!s) return;
        let spine = 0, done = 0;
        for (let i = 0; i < s.count; i += 4) { spine++; if (s.loaded.has(i)) done++; }
        pct.textContent = `${Math.min(100, Math.round((done / spine) * 100))} %`;
      }, 120);
    }

    // /suites → enquiry prefill: ?suite=<name>#enquire fills the hidden field + shows a chip.
    const suiteName = new URLSearchParams(location.search).get('suite');
    if (suiteName) {
      const form = document.querySelector('[data-inquiry]');
      const chip = document.querySelector('[data-inquiry-regarding]');
      const label = document.querySelector('[data-inquiry-suite]');
      const input = form?.querySelector('input[name="suite"]');
      if (input) input.value = suiteName;
      if (label) label.textContent = suiteName;
      if (chip) chip.hidden = false;
    }
  </script>
</Base>
