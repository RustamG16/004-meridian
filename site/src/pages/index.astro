---
import Base from '../layouts/Base.astro';
import { skin } from '../content/skin';
import { readdirSync } from 'node:fs';
import { fileURLToPath } from 'node:url';

const { journey, manifesto, factsBar, rooms, suitesPage, dining, amenities, about, rate, agent, cta, meta } = skin;

// Frame counts come from the files actually on disk, not a hand-typed number —
// a count/disk mismatch makes the scrubber request 404s and the hero appears frozen.
const countFrames = (dir: string) => {
  try {
    return readdirSync(fileURLToPath(new URL(`../../public/frames/${dir}/`, import.meta.url)))
      .filter((f) => /^frame_\d+\.webp$/.test(f)).length;
  } catch {
    return 0;
  }
};
const frames = {
  ...journey.frames,
  count: countFrames('v1') || journey.frames.count,
};
---

<Base>
  <!-- JOURNEY — continuous scroll-scrub (Video 1 drone descent). -->
  <section class="journey" id="tour" data-journey data-frames={JSON.stringify(frames)}>
    <div class="journey__sticky">
      <canvas data-journey-canvas></canvas>
      <div class="journey__scrim" aria-hidden="true"></div>
    </div>
  </section>

  <!-- MANIFESTO — display statement, no image -->
  <section class="manifesto" aria-label="Manifesto">
    <p class="kicker manifesto__kicker" data-reveal>{manifesto.kicker}</p>
    <div class="manifesto__lines" data-reveal>
      {manifesto.lines.map((line) => (
        <p class="manifesto__line">{line}</p>
      ))}
    </div>
    <hr class="manifesto__rule" aria-hidden="true" data-reveal />
  </section>

  <!-- QUICK FACTS — compact inline count-up row -->
  <section class="facts-bar" aria-label="The resort in numbers">
    <div class="facts-bar__row">
      {factsBar.items.map((f) => (
        <div class="facts-bar__item" data-reveal>
          <span
            class="facts-bar__value"
            data-count={f.value}
            data-format={'format' in f ? f.format : undefined}
            data-suffix={'suffix' in f ? f.suffix : undefined}
            data-decimals={'decimals' in f ? f.decimals : undefined}
          >0</span>
          <span class="facts-bar__label">{f.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- THE ROOMS — pinned horizontal carousel (lasala d-carousel-rooms), cards from suitesPage -->
  <section class="rooms" id="suites" data-hscroll>
    <div class="rooms__pin">
      <div class="rooms__head" data-reveal>
        <p class="kicker">{rooms.kicker}</p>
        <h2 class="section-title">{rooms.title}</h2>
        <p class="section-body">{rooms.body}</p>
        <a class="rooms__link" href={rooms.linkHref}>{rooms.linkLabel} →</a>
      </div>
      <div class="rooms__track" data-hscroll-track>
        {suitesPage.suites.map((s, i) => (
          <a class="rooms__card" href={`/suites#${s.id}`}>
            <div class="media rooms__media">
              <img data-media src={s.hero.src} alt={s.hero.alt} loading="lazy" />
              <span class="media__label" aria-hidden="true">{s.name}</span>
            </div>
            <div class="rooms__meta">
              <span class="rooms__no" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <span class="rooms__name">{s.name}</span>
              <span class="rooms__facts">{s.facts.area} · {s.facts.sleeps} · {s.rate}</span>
            </div>
            <p class="rooms__line">{s.line}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- DINING — 40/60 editorial teaser -->
  <section class="dining" aria-label="Dining">
    <div class="dining__copy" data-reveal>
      <p class="kicker">{dining.kicker}</p>
      <h2 class="section-title">{dining.title}</h2>
      <p class="section-body">{dining.body}</p>
      <p class="dining__signature">{dining.signature}</p>
      <a class="dining__link" href={dining.linkHref}>{dining.linkLabel} →</a>
    </div>
    <div class="dining__media">
      <img data-media src={dining.img} alt={dining.imgAlt} loading="lazy" />
    </div>
  </section>

  <!-- AMENITIES — wave marquee (rAF drift + sine Y; static scroll-snap fallback) -->
  <section class="amenities-wave" id="amenities" data-amenities-wave aria-label="Amenities">
    <div class="amenities-wave__head" data-reveal>
      <p class="kicker">{amenities.kicker}</p>
      <h2 class="section-title">{amenities.title}</h2>
    </div>
    <div class="amenities-wave__band" data-amenities-band>
      <div class="amenities-wave__track" data-amenities-track>
        {[0, 1].map((copy) =>
          amenities.items.map((item, i) => (
            <a
              class="am-card"
              href={`/amenities/${item.slug}`}
              data-am-card
              data-am-phase={i}
              aria-label={`${item.label} — Explore`}
              tabindex={copy === 0 ? 0 : -1}
            >
              <div class="media am-card__media">
                <img data-media src={item.img} alt="" loading="lazy" />
              </div>
              <span class="am-card__no" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="am-card__name">{item.label}</h3>
              <p class="am-card__line">{item.line}</p>
              <span class="am-card__cta" aria-hidden="true">Explore →</span>
            </a>
          ))
        )}
      </div>
    </div>
  </section>

  <!-- ABOUT / STORY — quiet two-column -->
  <section class="about" aria-label="About">
    <div class="about__copy" data-reveal>
      <p class="kicker">{about.kicker}</p>
      <h2 class="section-title">{about.title}</h2>
      {about.paragraphs.map((p) => (
        <p class="section-body about__p">{p}</p>
      ))}
    </div>
    <div class="about__media media" data-reveal>
      <img data-media src={about.img} alt={about.imgAlt} loading="lazy" />
    </div>
  </section>

  <!-- THE RATE + REQUEST — one closing statement (rate folded into the enquiry) -->
  <section class="inquiry" id="enquire">
    <p class="kicker" data-reveal>{rate.kicker}</p>
    <p class="inquiry__rate" data-reveal>{rate.amount}</p>
    <p class="inquiry__rate-line" data-reveal>{rate.line}</p>
    <h2 class="inquiry__title" data-reveal>{cta.title}</h2>
    <p class="section-body inquiry__sub" data-reveal>{cta.sub}</p>
    <div class="inquiry__grid" data-reveal>
      <form class="inquiry__form" data-inquiry novalidate>
        <p class="inquiry__regarding" data-inquiry-regarding hidden>
          Regarding: <span data-inquiry-regarding-label></span>
        </p>
        <input type="hidden" name="suite" />
        <input type="hidden" name="amenity" />
        <div class="inquiry__row">
          <label class="field">
            <span>{cta.fields.date}</span>
            <input type="date" name="date" required />
          </label>
          <label class="field field--wide">
            <span>{cta.fields.name}</span>
            <input type="text" name="name" required autocomplete="name" />
          </label>
        </div>
        <label class="field field--full">
          <span>{cta.fields.email}</span>
          <input type="email" name="email" required autocomplete="email" />
        </label>
        <button class="btn" type="submit">{cta.submit}</button>
        <p class="inquiry__toast" data-toast role="status" aria-live="polite" hidden>{cta.toast}</p>
      </form>
      <aside class:list={['agent', { 'agent--typo': !agent.showPortrait }]}>
        {agent.showPortrait && (
          <div class="media media--agent">
            <img data-media src={agent.img} alt={agent.imgAlt} loading="lazy" />
          </div>
        )}
        <p class="agent__kicker kicker">{agent.kicker}</p>
        <div class="agent__rule" aria-hidden="true"></div>
        <h3 class="agent__name">{agent.name}</h3>
        <p class="agent__role">{agent.role}</p>
        {agent.lines.map((line) => <p class="agent__line">{line}</p>)}
        <p class="agent__contact">
          <a href={meta.telHref}>{meta.tel}</a><br />
          <a href={`mailto:${meta.email}`}>{meta.email}</a>
        </p>
      </aside>
    </div>
  </section>

  <script src="../scripts/journey.js"></script>
  <script>
    // Scroll-driven horizontal panels (ROOMS) — property-level; engine stays fork-free.
    // The pin is CSS sticky; this only maps each section's progress -> track translateX.
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const panels = [...document.querySelectorAll('[data-hscroll]')].map((section) => ({
      section,
      track: section.querySelector('[data-hscroll-track]'),
    })).filter((p) => p.track);
    if (panels.length && !reduced) {
      let ticking = false;
      const update = () => {
        ticking = false;
        for (const { section, track } of panels) {
          const r = section.getBoundingClientRect();
          if (r.bottom < 0 || r.top > innerHeight) continue;
          const total = section.offsetHeight - innerHeight;
          const p = total <= 0 ? 1 : Math.max(0, Math.min(1, -r.top / total));
          const max = track.scrollWidth - track.parentElement.clientWidth;
          track.style.transform = `translate3d(${-p * Math.max(0, max)}px, 0, 0)`;
        }
      };
      addEventListener('scroll', () => { if (!ticking) { ticking = true; requestAnimationFrame(update); } }, { passive: true });
      addEventListener('resize', update);
      update();
    }

    // Preloader %: real coarse-spine (every 4th frame) load progress, not a timer.
    const pct = document.querySelector('[data-preload-pct]');
    if (pct && !reduced) {
      const timer = setInterval(() => {
        const s = window.__scrubber;
        const pre = document.querySelector('[data-preloader]');
        if (!pre || pre.classList.contains('is-done')) { clearInterval(timer); return; }
        if (!s) return;
        let spine = 0, done = 0;
        for (let i = 0; i < s.count; i += 4) { spine++; if (s.loaded.has(i)) done++; }
        pct.textContent = `${Math.min(100, Math.round((done / spine) * 100))} %`;
      }, 120);
    }

    // Enquiry prefill: ?suite= or ?amenity= fills hidden field + shows a chip.
    const params = new URLSearchParams(location.search);
    const suiteName = params.get('suite');
    const amenityName = params.get('amenity');
    const regarding = suiteName || amenityName;
    if (regarding) {
      const form = document.querySelector('[data-inquiry]');
      const chip = document.querySelector('[data-inquiry-regarding]');
      const label = document.querySelector('[data-inquiry-regarding-label]');
      if (suiteName) {
        const input = form?.querySelector('input[name="suite"]');
        if (input) input.value = suiteName;
      }
      if (amenityName) {
        const input = form?.querySelector('input[name="amenity"]');
        if (input) input.value = amenityName;
      }
      if (label) label.textContent = regarding;
      if (chip) chip.hidden = false;
    }
  </script>
</Base>
