---
import '../styles/global.css';
import { skin } from '../content/skin';

const { meta, fonts, tokens, preloader, nav, menu, footer } = skin;
const cssVars = `:root{--bg:${tokens.bg};--text:${tokens.text};--dim:${tokens.dim};--accent-summer:${tokens.accent};--accent-winter:${tokens.accentWinter};--accent:${tokens.accent};--display:'${fonts.display}',serif;--body:'${fonts.body}',sans-serif;}`;
---

<!doctype html>
<html lang={meta.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    {meta.noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="theme-color" content={tokens.bg} />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:image" content="/og.jpg" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={fonts.href} rel="stylesheet" />
    <link rel="preload" as="image" href="/frames/hero/frame_0001.webp" />
    <style set:html={cssVars}></style>
  </head>
  <body id="top">
    <div class="grain" aria-hidden="true"></div>
    <div class="lightshaft" aria-hidden="true"></div>

    <div class="preloader" data-preloader aria-hidden="true">
      <p class="preloader__line">{preloader.line}</p>
    </div>

    <header class="topbar">
      <button class="topbar__menu" data-menu-open aria-haspopup="dialog" aria-controls="site-menu">
        <span class="topbar__menu-icon" aria-hidden="true"></span>{nav.menuLabel}
      </button>
      <span class="topbar__mark">{meta.name}</span>
      <a class="topbar__cta" href="#enquire">{nav.cta}</a>
    </header>

    <div class="menu" id="site-menu" data-menu-root role="dialog" aria-modal="true" aria-label="Site menu" hidden>
      <div class="menu__overlay" data-menu-overlay></div>
      <nav class="menu__panel">
        <button class="menu__close" data-menu-close>
          <span aria-hidden="true">✕</span> {nav.menuLabel}
        </button>
        <ul class="menu__links">
          {menu.links.map((l) => (
            <li class="menu__item"><a class="menu__link" href={l.href} data-menu-link>{l.label}</a></li>
          ))}
        </ul>
        <p class="menu__group-label">{menu.groupLabel}</p>
        <ul class="menu__links menu__links--group">
          {menu.groupLinks.map((l) => (
            <li class="menu__item">
              <a class="menu__link menu__link--sub" href="#tour" data-menu-link data-journey-progress={l.progress}>{l.label}</a>
            </li>
          ))}
        </ul>
        <div class="menu__foot">
          <p class="menu__handle">{menu.handle}</p>
          <p class="menu__tagline">{menu.tagline[0]}<br />{menu.tagline[1]}</p>
        </div>
      </nav>
    </div>

    <slot />

    <footer class="footer">
      <p class="footer__wordmark" aria-hidden="true">{footer.wordmark}</p>
      <div class="footer__row">
        <span>{meta.fullName}</span>
        <span>{meta.address}</span>
        <span><a href={meta.telHref}>{meta.tel}</a> · <a href={`mailto:${meta.email}`}>{meta.email}</a></span>
      </div>
      <div class="footer__row footer__row--legal">
        <span>{footer.note}</span>
        <span>{footer.legal}</span>
      </div>
    </footer>

    <script src="../scripts/ui.js"></script>
    <script src="../scripts/menu.js"></script>
  </body>
</html>
